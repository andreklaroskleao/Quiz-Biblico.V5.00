rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    match /users/{uid} {
      allow read: if signedIn() && (resource.data.privacy == 'public' || isOwner(uid) || isAdmin());
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /questions/{qid} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /questionReports/{rid} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /friendRequests/{rid} {
      allow create: if signedIn() && request.resource.data.from == request.auth.uid;
      allow read: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid || isAdmin());
      allow update: if signedIn() && (resource.data.to == request.auth.uid || isAdmin());
      allow delete: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid || isAdmin());
    }

    match /rooms/{roomId} {
      allow create: if signedIn() && request.resource.data.leaderId == request.auth.uid;
      allow read: if signedIn();
      allow update: if signedIn() && (
        resource.data.leaderId == request.auth.uid ||
        request.auth.uid in resource.data.players ||
        request.auth.uid in request.resource.data.players ||
        isAdmin()
      );
      allow delete: if isAdmin() || (signedIn() && resource.data.leaderId == request.auth.uid);
    }

    match /tournaments/{tid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() || isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
