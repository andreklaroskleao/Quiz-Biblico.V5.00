rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.leaderId == request.auth.uid
        && request.resource.data.players.hasOnly([request.auth.uid]);
      allow update: if signedIn() && (
        resource.data.leaderId == request.auth.uid ||
        request.auth.uid in resource.data.players ||
        request.auth.uid in request.resource.data.players
      );
      allow delete: if signedIn() && resource.data.leaderId == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.status == 'pending';
      allow update: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow delete: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.players;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn() && request.auth.uid in resource.data.players;
      allow delete: if false;
    }
  }
}
